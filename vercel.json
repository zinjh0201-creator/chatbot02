{
  "version": 2,
  "builds": [
    { "src": "backend/app/main.py", "use": "@vercel/python" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/app/main.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ]
}
